{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Payment Resilience (PG Circuit Breaker)",
  "uid": "payment-resilience",
  "tags": ["payment", "resilience4j"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "schemaVersion": 39,
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "current-circuit-status",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "resilience4j_circuitbreaker_state{name=\"pg\", state=\"open\"}", "legendFormat": "OPEN", "refId": "A" },
        { "expr": "resilience4j_circuitbreaker_state{name=\"pg\", state=\"half_open\"}", "legendFormat": "HALF_OPEN", "refId": "B" },
        { "expr": "resilience4j_circuitbreaker_state{name=\"pg\", state=\"closed\"}", "legendFormat": "CLOSED", "refId": "C" }
      ]
    },
    {
      "id": 2,
      "title": "current-circuit-change-timeline",
      "type": "state-timeline",
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "mergeValues": true, "showValue": "auto" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80 },
          "mappings": [ { "type": "value", "options": { "1": { "text": "ON", "color": "red" }, "0": { "text": "", "color": "transparent" } } } ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "resilience4j_circuitbreaker_state{name=\"pg\", state=\"open\"}", "legendFormat": "OPEN", "refId": "A" },
        { "expr": "resilience4j_circuitbreaker_state{name=\"pg\", state=\"half_open\"}", "legendFormat": "HALF_OPEN", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "title": "retry (retry calls / s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (kind) (rate(resilience4j_retry_calls_total{name=\"pg\"}[1m]))", "legendFormat": "{{kind}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "circuit-result (calls / s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{name=\"pg\"}[1m]))", "legendFormat": "{{kind}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "external-api-delay (P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/payments\"}[1m])) by (le))", "legendFormat": "P95", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{uri=\"/api/v1/payments\"}[1m])) by (le))", "legendFormat": "P99", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "title": "external-api-throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/payments\"}[1m]))", "legendFormat": "throughput", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "external-api-error-ratio (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/payments\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{uri=\"/api/v1/payments\"}[1m]))", "legendFormat": "error rate", "refId": "A" }
      ]
    }
  ]
}
