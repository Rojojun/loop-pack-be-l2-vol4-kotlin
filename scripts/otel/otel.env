# OTEL Java Agent 환경변수 — 트레이스만 export (메트릭/로그는 기존 Prometheus/logback 유지).
OTEL_SERVICE_NAME=commerce-api
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# Tempo OTLP 수신 (monitoring-compose 의 tempo:4317 → host 매핑)
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# 부하 측정이라 전량 샘플링. TODO(직접): 운영 전환 시 ratio 로 낮출 것.
OTEL_TRACES_SAMPLER=parentbased_always_on

# SELECT 쿼리 텍스트를 span attribute(db.statement) 로 기록 → 무거운 GROUP BY 식별의 핵심.
OTEL_INSTRUMENTATION_JDBC_STATEMENT_SANITIZER_ENABLED=true
